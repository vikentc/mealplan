{
  "name": "mealplanner",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "export DATABASE_URL=\"${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/meal_planner?schema=public}\" && prisma generate && ([ -n \"$VERCEL\" ] && echo 'Skipping DB push on Vercel' || prisma db push || echo 'Warning: Could not push schema updates to DB') && next build",
    "start": "next start",
    "postinstall": "export DATABASE_URL=\"${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/meal_planner?schema=public}\" && prisma generate",
    "prisma:generate": "export DATABASE_URL=\"${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/meal_planner?schema=public}\" && prisma generate",
    "prisma:push": "export DATABASE_URL=\"${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/meal_planner?schema=public}\" && prisma db push",
    "seed": "node scripts/seed.js",
    "db:cleanup": "node scripts/cleanup-db-duplicates.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "clsx": "^2.1.1",
    "firebase": "^12.15.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "lightningcss-darwin-arm64": "^1.32.0"
  }
}
